# ====================================
# TRADING BOT CONFIGURATION
# ====================================

# Database (Required) - Create database: mysql -u root -p -e "CREATE DATABASE trading_bot;"
DATABASE_URL=mysql://root:your_password@localhost:3306/trading_bot

# Server Settings
PORT=3000
NODE_ENV=development

# JWT Secret (Required) - Use any random string
JWT_SECRET=change-this-to-a-random-secret-string-12345

# ====================================
# MARKET DATA - NOW USING FREE API!
# ====================================
# Market data now uses Yahoo Finance public API (FREE)
# No API key required!

# ====================================
# UI SETTINGS (Required for Vite build)
# ====================================
VITE_APP_TITLE="Trading Bot"
VITE_APP_LOGO="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📈</text></svg>"
VITE_APP_ID=trading-bot-app

# ====================================
# OAUTH SETTINGS (Optional - Not needed for basic trading)
# ====================================
# VITE_OAUTH_PORTAL_URL=https://vida.butterfly-effect.dev
# OAUTH_SERVER_URL=https://vidabiz.butterfly-effect.dev
# OWNER_OPEN_ID=

# ====================================
# ANALYTICS (Optional - leave empty to disable)
# ====================================
VITE_ANALYTICS_ENDPOINT=""
VITE_ANALYTICS_WEBSITE_ID=""

# ====================================
# OPENAI (Optional - For future AI features)
# ====================================
# OPENAI_API_KEY=your-openai-api-key-here
