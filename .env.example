# ====================================
# TRADING BOT CONFIGURATION
# ====================================

# Database (Required) - Create database: mysql -u root -p -e "CREATE DATABASE trading_bot;"
DATABASE_URL=mysql://root:your_password@localhost:3306/trading_bot

# Server Settings
PORT=3000
NODE_ENV=development

# JWT Secret (Required) - Use any random string
JWT_SECRET=change-this-to-a-random-secret-string-12345

# ====================================
# MARKET DATA - NOW USING FREE API!
# ====================================
# Market data now uses Yahoo Finance public API (FREE)
# No API key required!
# BUILT_IN_FORGE_API_URL and BUILT_IN_FORGE_API_KEY are no longer needed

# ====================================
# OPTIONAL OAUTH SETTINGS (Not needed for trading)
# ====================================
